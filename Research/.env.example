# Interactive Brokers Gateway configuration (ib-gateway-docker).
# Copy this file to `.env` and fill in your own values. Do NOT commit a real `.env`.
# See: https://github.com/gnzsnz/ib-gateway-docker for full documentation.

# --- IBKR login ---
TWS_USERID=
TWS_PASSWORD=

# --- Gateway / TWS behaviour ---
TWS_SETTINGS_PATH=
TWS_ACCEPT_INCOMING=
TRADING_MODE=paper
READ_ONLY_API=no
VNC_SERVER_PASSWORD=
TWOFA_TIMEOUT_ACTION=restart
TWOFA_DEVICE=
BYPASS_WARNING=
AUTO_RESTART_TIME=
AUTO_LOGOFF_TIME=
TWS_COLD_RESTART=
SAVE_TWS_SETTINGS=
RELOGIN_AFTER_TWOFA_TIMEOUT=yes
EXISTING_SESSION_DETECTED_ACTION=primary
ALLOW_BLIND_TRADING=no
TIME_ZONE=Europe/Amsterdam
CUSTOM_CONFIG=

# --- Optional SSH tunnel ---
SSH_TUNNEL=
SSH_OPTIONS=
SSH_ALIVE_INTERVAL=
SSH_ALIVE_COUNT=
SSH_PASSPHRASE=
SSH_REMOTE_PORT=
SSH_USER_TUNNEL=
SSH_RESTART=
SSH_VNC_PORT=
